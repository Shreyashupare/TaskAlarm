{
  "name": "taskalarm",
  "version": "1.0.0",
  "description": "`TaskAlarm` is a simple alarm app that requires short tasks before stop is unlocked.",
  "main": "expo/AppEntry",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --passWithNoTests",
    "precommit:check": "npm run typecheck && npm run test:ci",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shreyashupare/TaskAlarm.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Shreyashupare/TaskAlarm/issues"
  },
  "homepage": "https://github.com/Shreyashupare/TaskAlarm#readme",
  "dependencies": {
    "expo": "^55.0.13",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
